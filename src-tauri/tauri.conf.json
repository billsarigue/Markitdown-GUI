{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markitdown GUI",
  "version": "0.1.0",
  "identifier": "com.zionlux.markitdown-gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Markitdown GUI",
        "width": 1100,
        "height": 720,
        "minWidth": 860,
        "minHeight": 580,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/markitdown"
    ],
    "publisher": "ZionLux",
    "copyright": "© 2025 ZionLux. All rights reserved.",
    "shortDescription": "Interface gráfica para o MarkItDown da Microsoft",
    "longDescription": "Markitdown GUI é uma interface gráfica moderna para o MarkItDown da Microsoft, permitindo converter documentos PDF, Word, PowerPoint, Excel, HTML e muito mais para Markdown com facilidade.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "pt-BR"
      },
      "nsis": {
        "languages": ["Portuguese"],
        "displayLanguageSelector": false,
        "installMode": "both",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installerSidebar": null,
        "headerImage": null
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      },
      "category": "Utility"
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
